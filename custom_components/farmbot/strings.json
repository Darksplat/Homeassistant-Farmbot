      "mqtt_connected": {"name": "MQTT connected"},
      "status_fresh": {"name": "Status fresh"},
      "emergency_stop": {"name": "Emergency stop"},
      "busy": {"name": "Busy"},
      "fully_online": {"name": "Fully online"}
    },
    "sensor": {
      "last_status_received": {"name": "Last status received"}
    }
