{
  "title": "FarmBot",
  "config": {
    "step": {
      "user": {
        "title": "Connect FarmBot",
        "description": "Enter the encoded FarmBot token and the bot and MQTT details supplied with the token.",
        "data": {
          "token": "Encoded token",
          "device_id": "Device ID",
          "mqtt_host": "MQTT host"
        }
      },
      "reauth_confirm": {
        "title": "Reconnect FarmBot",
        "description": "Enter a replacement encoded FarmBot token.",
